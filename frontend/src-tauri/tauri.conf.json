{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Growth Companion",
  "version": "0.1.0",
  "identifier": "com.growth-companion.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "taskkill /F /IM growth-companion.exe 2>nul & npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Growth Companion",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/growth-companion/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "macOS": {
      "minimumSystemVersion": "15.0"
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
